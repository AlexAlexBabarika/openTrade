{
  "name": "opentrade-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder build --dir",
    "compile:electron": "tsc -p tsconfig.electron.json && node -e \"require('fs').writeFileSync('dist-electron/package.json', JSON.stringify({type:'commonjs'}))\"",
    "build:electron": "npm run compile:electron && vite build",
    "electron:dev": "npm run compile:electron && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build:electron && electron-builder",
    "preview": "vite preview",
    "format": "prettier --write .",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "lightweight-charts": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "4.0.18",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "prettier": "3.8.1",
    "typescript": "^5.3.3",
    "vite": "^7.0.0",
    "vitest": "4.0.18",
    "wait-on": "^7.2.0"
  }
}
