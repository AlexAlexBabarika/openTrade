# Copy to .env in project root and fill in values.
# For local Supabase: run `supabase start` and copy the API URL and service_role key.
# For production: set SUPABASE_REQUIRED=1 to fail startup if Supabase is not configured.
#
# When running the backend via Docker Compose, use host.docker.internal
# instead of 127.0.0.1 so the container can reach Supabase on the host:
#   SUPABASE_URL=http://host.docker.internal:54321
#
# When running the backend directly (no Docker), use 127.0.0.1:
#   SUPABASE_URL=http://127.0.0.1:54321

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-start

# Set to 1 in production (HTTPS) so the refresh_token cookie has the Secure flag.
# Leave at 0 for local development over plain HTTP.
COOKIE_SECURE=0

# 64 hex chars (32 bytes). Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_KEYS_ENCRYPTION_KEY=
