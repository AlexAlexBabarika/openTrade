# Copy to .env in project root and fill in values.
# For local Supabase: run `supabase start` and copy the API URL and service_role key.
# For production: set SUPABASE_REQUIRED=1 to fail startup if Supabase is not configured.

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-start